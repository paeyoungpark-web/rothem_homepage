{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile data referencing the Firebase Auth UID",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "description": "User's email address"
        },
        "displayName": {
          "type": "string",
          "description": "User's display name"
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp of creation"
        },
        "updatedAt": {
          "type": "string",
          "description": "Timestamp of last update"
        }
      },
      "required": ["email", "displayName", "createdAt", "updatedAt"]
    },
    "Insight": {
      "title": "Insight",
      "description": "Security Insight article either generated by Gemini AI or manually authored by an Administrator",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "category": { "type": "string" },
        "date": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "published", "archived"] },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["title", "content", "category", "date", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "Information about extra products",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the product"
        },
        "description": {
          "type": "string",
          "description": "Description of the product"
        }
      },
      "required": ["name", "description"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profile information"
    },
    "/insights/{insightId}": {
      "schema": {
        "$ref": "#/entities/Insight"
      },
      "description": "Stores security insights/articles generated automatically or manually"
    },
    "/products/{productId}": {
      "schema": {
        "$ref": "#/entities/Product"
      },
      "description": "Stores extra products information"
    }
  }
}
